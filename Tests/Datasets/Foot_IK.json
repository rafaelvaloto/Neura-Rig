{
  "Profile": "Foot_IK",
  "Version": 3,
  "Schema": {
    "Inputs": [
      { "Name": "velocity",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 0 },

      { "Name": "bone_l1_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 1 },
      { "Name": "bone_l2_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 2 },
      { "Name": "bone_l3_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 3 },
      { "Name": "bone_l4_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 4 },
      { "Name": "is_hit_0",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 5 },

      { "Name": "offset_0",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 6 },
      { "Name": "spacing_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 7 },

      { "Name": "bone_l1_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 8 },
      { "Name": "bone_l2_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 9 },
      { "Name": "bone_l3_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 10 },
      { "Name": "bone_l4_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 11 },
      { "Name": "is_hit_1",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 12 },

      { "Name": "offset_1",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 13 },
      { "Name": "spacing_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 14 },

      { "Name": "t_cycle",         "Space": "-",  "Type": "float", "Size": 1, "Offset": 15 },
      { "Name": "time_dilation",   "Space": "-",  "Type": "float", "Size": 1, "Offset": 16 },
      { "Name": "reserved",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 17 }
    ],
    "Bindings": [
      { "Name": "foot_r", "Target": "Humanoid_Foot_Ik_Curve", "Size": 6, "Offset": 0 },
      { "Name": "foot_l", "Target": "Humanoid_Foot_Ik_Curve", "Size": 6, "Offset": 6 },
      { "Name": "ball_r", "Target": "Humanoid_Ball_Ik_Curve", "Size": 6, "Offset": 12},
      { "Name": "ball_l", "Target": "Humanoid_Ball_Ik_Curve", "Size": 6, "Offset": 18},
      { "Name": "calf_r", "Target": "Humanoid_Calf_Ik_Curve", "Size": 6, "Offset": 24},
      { "Name": "calf_l", "Target": "Humanoid_Calf_Ik_Curve", "Size": 6, "Offset": 30},
      { "Name": "thigh_r", "Target": "Humanoid_Thigh_Ik_Curve", "Size": 6, "Offset": 36},
      { "Name": "thigh_l", "Target": "Humanoid_Thigh_Ik_Curve", "Size": 6, "Offset": 42},
      { "Name": "pelvis", "Target": "Humanoid_Pelvis_Ik_Curve", "Size": 6, "Offset": 48},
      { "Name": "spine",  "Target": "Humanoid_Spine_Ik_Curve", "Size": 6, "Offset": 54}
    ],
    "Parameters": {
      "Constants": {
        "gait_scale": 2.2,
        "step_height": 0.45,
        "max_pitch_norm": 0.65
      },
      "Variables": {
        "velocity": ["velocity", "velocity"],
        "is_hit"  : ["is_hit_0", "is_hit_1"],
        "offset"  : ["offset_0", "offset_1"],
        "spacing" : ["spacing_0", "spacing_1"],
        "bone_l1" : ["bone_l1_0", "bone_l1_1"],
        "bone_l2" : ["bone_l2_0", "bone_l2_1"],
        "bone_l3" : ["bone_l3_0", "bone_l3_1"],
        "bone_l4" : ["bone_l4_0", "bone_l4_1"],
        "t_cycle" : ["t_cycle", "t_cycle"]
      }
    },
    "Rules": [
      {
        "Name": "Humanoid_Foot_Ik_Curve",
        "Logic": {
          "stride_len": "sqrt(velocity / (bone_l1 + bone_l2 + bone_l3 + bone_l4))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 0.85, step_height)",
          "p_offset": "(bone_l1 + bone_l2 + bone_l3)"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "p_offset",
            "offset_y": "((linear_cycle + 0.5) * stride_len)",
            "offset_z": "spacing",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "(p_offset - (height_offset * sin(_pi * linear_cycle)))",
            "offset_y": "-((linear_cycle - 0.5) * stride_len)",
            "offset_z": "spacing",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Ball_Ik_Curve",
        "Logic": {
          "stride_len": "sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 0.6, step_height)"
        },
        "Phases": [
          {
            "id": "toe_off",
            "condition": "linear_cycle > -0.4 && linear_cycle < 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          },
          {
            "id": "landing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Calf_Ik_Curve",
        "Limits": { "MinX": -90.0, "MaxX": 15.0, "MinY": 0.0, "MaxY": 0.0, "MinZ": 0.0, "MaxZ": 0.0 },
        "Logic": {
          "stride_len": "sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Thigh_Ik_Curve",
        "Limits": { "MinX": -180.0, "MaxX": 195.0, "MinY": -10.0, "MaxY": 10.0, "MinZ": -15.0, "MaxZ": 15.0 },
        "Logic": {
          "stride_len": "sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Pelvis_Ik_Curve",
        "Limits": { "MinX": -360.0, "MaxX": 360.0, "MinY": -360.0, "MaxY": 360.0, "MinZ": 0.0, "MaxZ": 0.0 },
        "Logic": {
          "stride_len": "sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "(bone_l1 + bone_l2 + bone_l3 + bone_l4)",
            "rot_pitch": "0.0",
            "rot_yaw": "1.570796",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Spine_Ik_Curve",
        "Logic": {
          "stride_len": "sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 0.6, step_height)"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "clamp(velocity / 1.0, 0.0, 1.0)",
            "rot_yaw": "-sin(_pi * linear_cycle)",
            "rot_roll": "-sin(_pi * linear_cycle) * 0.5"
          }
        ]
      },
      {
        "Name": "Humanoid_Arm_Ik_Curve",
        "Logic": {
          "stride_len": "sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 0.6, step_height)"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "sin(_pi * linear_cycle)",
            "rot_yaw": "0.0",
            "rot_roll": "(cos(2.0 * _pi * linear_cycle) - 1.0) * 0.5"
          }
        ]
      }
    ],
    "Outputs": [
      { "Name": "foot_ik", "Space": "LS", "Type": "vec3",  "Size": 24, "Offset": 0 },
      { "Name": "legs_ik", "Space": "LS", "Type": "vec3",  "Size": 24, "Offset": 24 },
      { "Name": "pelvis_ik", "Space": "LS", "Type": "vec3", "Size": 6, "Offset": 48 },
      { "Name": "spine_ik",  "Space": "LS", "Type": "vec3", "Size": 6, "Offset": 54 }
    ]
  }
}