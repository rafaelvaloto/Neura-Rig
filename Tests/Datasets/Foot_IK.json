{
  "Profile": "Foot_IK",
  "Version": 1,
  "Schema": {
    "Inputs": [
      { "Name": "velocity",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 0 },
      { "Name": "bone_l0",         "Space": "-",  "Type": "float", "Size": 1, "Offset": 1 },

      { "Name": "bone_l1_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 2 },
      { "Name": "bone_l2_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 3 },
      { "Name": "bone_l3_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 4 },
      { "Name": "bone_l4_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 5 },

      { "Name": "bone_l3_0_hit",    "Space": "-",  "Type": "float", "Size": 1, "Offset": 6 },
      { "Name": "bone_l3_0_offset", "Space": "-",  "Type": "float", "Size": 1, "Offset": 7 },
      { "Name": "bone_l3_0_spacing","Space": "-",  "Type": "float", "Size": 1, "Offset": 8 },

      { "Name": "bone_l1_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 9 },
      { "Name": "bone_l2_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 10 },
      { "Name": "bone_l3_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 11 },
      { "Name": "bone_l4_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 12 },

      { "Name": "bone_l3_1_hit",      "Space": "-",  "Type": "float", "Size": 1, "Offset": 13 },
      { "Name": "bone_l3_1_offset",   "Space": "-",  "Type": "float", "Size": 1, "Offset": 14 },
      { "Name": "bone_l3_1_spacing",  "Space": "-",  "Type": "float", "Size": 1, "Offset": 15 },
      { "Name": "bone_l0_x",          "Space": "WS", "Type": "float", "Size": 1, "Offset": 16 },
      { "Name": "bone_l0_y",          "Space": "WS", "Type": "float", "Size": 1, "Offset": 17 },
      { "Name": "bone_l0_z",          "Space": "WS", "Type": "float", "Size": 1, "Offset": 18 },
      { "Name": "bone_l0_q1",         "Space": "WS", "Type": "float", "Size": 1, "Offset": 19 },
      { "Name": "bone_l0_q2",         "Space": "WS", "Type": "float", "Size": 1, "Offset": 20 },
      { "Name": "bone_l0_q3",         "Space": "WS", "Type": "float", "Size": 1, "Offset": 21 },
      { "Name": "bone_l0_qw",         "Space": "WS", "Type": "float", "Size": 1, "Offset": 22 },

      { "Name": "t_cycle",      "Space": "-",  "Type": "float", "Size": 1, "Offset": 23 },
      { "Name": "t_dilation",   "Space": "-",  "Type": "float", "Size": 1, "Offset": 24 },
      { "Name": "reserved",     "Space": "-",  "Type": "float", "Size": 1, "Offset": 25 }
    ],
    "Bindings": [
      { "Name": "pelvis", "Target": "Humanoid_Rest_Pose_Pelvis_Target", "Size": 7, "Offset": 0 },
      { "Name": "foot_r", "Target": "Humanoid_Foot_Ik_Target", "Size": 7, "Offset": 21 },
      { "Name": "foot_l", "Target": "Humanoid_Foot_Ik_L_Target", "Size": 7, "Offset": 42 }
    ],
    "Parameters": {
      "Constants": {
        "k": 1.2,
        "gait_scale": 1.8,
        "step_height": 0.30
      },
      "Variables": {
        "bone_l0" : ["bone_l0", "bone_l0"],
        "bone_l1" : ["bone_l1_0", "bone_l1_1"],
        "bone_l2" : ["bone_l2_0", "bone_l2_1"],
        "bone_l3" : ["bone_l3_0", "bone_l3_1"],
        "bone_l4" : ["bone_l4_0", "bone_l4_1"],
        "is_hit"  : ["bone_l3_0_hit", "bone_l3_1_hit"],
        "offset"  : ["bone_l3_0_offset", "bone_l3_1_offset"],
        "spacing" : ["bone_l3_0_spacing", "bone_l3_1_spacing"],
        "velocity": ["velocity", "velocity"],
        "t_cycle" : ["t_cycle", "t_cycle"],
        "bone_l0_ws_x" : ["bone_l0_x", "bone_l0_x"],
        "bone_l0_ws_y" : ["bone_l0_y", "bone_l0_y"],
        "bone_l0_ws_z" : ["bone_l0_z", "bone_l0_z"],
        "bone_l0_ws_q1" : ["bone_l0_q1", "bone_l0_q1"],
        "bone_l0_ws_q2" : ["bone_l0_q2", "bone_l0_q2"],
        "bone_l0_ws_q3" : ["bone_l0_q3", "bone_l0_q3"],
        "bone_l0_ws_qw" : ["bone_l0_qw", "bone_l0_qw"]
      }
    },
    "Rules": [
      {
        "Name": "Humanoid_Rest_Pose_Pelvis_Target",
        "Logic": {
          "p_Offset": "0.0"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "bone_l0_ws_x",
            "offset_y": "bone_l0_ws_y",
            "offset_z": "bone_l0_ws_z",
            "q1": "bone_l0_ws_q1",
            "q2": "bone_l0_ws_q2",
            "q3": "bone_l0_ws_q3",
            "qw": "bone_l0_ws_qw"
          }
        ]
      },
      {
        "Name": "Humanoid_Foot_Ik_Target",
        "Logic": {
          "l2_offset": "bone_l2",
          "f_offset": "(bone_l1 + bone_l2)",
          "stride_len": "k * f_offset * sqrt(velocity / f_offset)",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "step_height"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "l2_offset",
            "offset_y": "-((linear_cycle + 0.5) * stride_len)",
            "offset_z": "(f_offset)"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "l2_offset",
            "offset_y": "((linear_cycle - 0.5) * stride_len)",
            "offset_z": "f_offset - ( height_offset * sin( _pi * linear_cycle) )"
          }
        ]
      },
      {
        "Name": "Humanoid_Foot_Ik_L_Target",
        "Logic": {
          "l2_offset": "bone_l2",
          "f_offset": "(bone_l1 + bone_l2)",
          "stride_len": "k * f_offset * sqrt(velocity / f_offset)",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "step_height"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "-l2_offset",
            "offset_y": "-((linear_cycle + 0.5) * stride_len)",
            "offset_z": "(f_offset)"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "-l2_offset",
            "offset_y": "((linear_cycle - 0.5) * stride_len)",
            "offset_z": "f_offset - ( height_offset * sin( _pi * linear_cycle) )"
          }
        ]
      }
    ],
    "Outputs": [
      { "Name": "pelvis_ik", "Space": "LS", "Type": "vec3|Quat", "Size": 7,  "Offset": 0 },
      { "Name": "leg_ik_r",  "Space": "LS", "Type": "vec3|Quat", "Size": 21, "Offset": 7 },
      { "Name": "leg_ik_l",  "Space": "LS", "Type": "vec3|Quat", "Size": 21, "Offset": 28 }
    ]
  }
}