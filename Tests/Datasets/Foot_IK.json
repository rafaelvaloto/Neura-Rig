{
  "Profile": "Foot_IK",
  "Version": 3,
  "Schema": {
    "Inputs": [
      { "Name": "velocity",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 0 },

      { "Name": "bone_l1_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 1 },
      { "Name": "bone_l2_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 2 },
      { "Name": "bone_l3_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 3 },
      { "Name": "bone_l4_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 4 },
      { "Name": "is_hit_0",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 5 },

      { "Name": "offset_0",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 6 },
      { "Name": "spacing_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 7 },

      { "Name": "bone_l1_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 8 },
      { "Name": "bone_l2_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 9 },
      { "Name": "bone_l3_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 10 },
      { "Name": "bone_l4_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 11 },
      { "Name": "is_hit_1",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 12 },

      { "Name": "offset_1",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 13 },
      { "Name": "spacing_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 14 },

      { "Name": "t_cycle",         "Space": "-",  "Type": "float", "Size": 1, "Offset": 15 },
      { "Name": "time_dilation",   "Space": "-",  "Type": "float", "Size": 1, "Offset": 16 },
      { "Name": "reserved",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 17 }
    ],
    "Bindings": [
      { "Name": "pelvis", "Target": "Humanoid_Pelvis_Ik", "Limits": { "MinX": -10.0, "MaxX": 10.0, "MinY": -10.0, "MaxY": 10.0, "MinZ": -10.0, "MaxZ": 10.0 }, "Size": 7, "Offset": 0},

      { "Name": "foot_r", "Target": "Humanoid_Foot_Ik_Target", "Limits": { "MinX": -45.0, "MaxX": 45.0, "MinY": -20.0, "MaxY": 20.0, "MinZ": -30.0, "MaxZ": 30.0 },   "Size": 7, "Offset": 7 },
      { "Name": "foot_l", "Target": "Humanoid_Foot_Ik_Target", "Limits": { "MinX": -45.0, "MaxX": 45.0, "MinY": -20.0, "MaxY": 20.0, "MinZ": -30.0, "MaxZ": 30.0 },   "Size": 7, "Offset": 14},

      { "Name": "calf_r", "Target": "Humanoid_Calf_Ik", "Limits": { "MinX": -140.0, "MaxX": 5.0, "MinY": -0.0, "MaxY": 0.0, "MinZ": -0.0, "MaxZ": 0.0 }, "Size": 7, "Offset": 21},
      { "Name": "calf_l", "Target": "Humanoid_Calf_Ik", "Limits": { "MinX": -140.0, "MaxX": 5.0, "MinY": -0.0, "MaxY": 0.0, "MinZ": -0.0, "MaxZ": 0.0 }, "Size": 7, "Offset": 28},

      { "Name": "thigh_r", "Target": "Humanoid_Thigh_Ik", "Limits": { "MinX": -120.0, "MaxX": 30.0, "MinY": -45.0, "MaxY": 30.0, "MinZ": -40.0, "MaxZ": 50.0 }, "Size": 7, "Offset": 35},
      { "Name": "thigh_l", "Target": "Humanoid_Thigh_Ik", "Limits": { "MinX": -120.0, "MaxX": 30.0, "MinY": -30.0, "MaxY": 45.0, "MinZ": -50.0, "MaxZ": 40.0 }, "Size": 7, "Offset": 42}
    ],
    "Parameters": {
      "Constants": {
        "k": 1.2,
        "gait_scale": 0.8,
        "step_height": 0.30,
        "max_pitch_norm": 0.25
      },
      "Variables": {
        "velocity": ["velocity", "velocity"],
        "is_hit"  : ["is_hit_0", "is_hit_1"],
        "offset"  : ["offset_0", "offset_1"],
        "spacing" : ["spacing_0", "spacing_1"],
        "bone_l1" : ["bone_l1_0", "bone_l1_1"],
        "bone_l2" : ["bone_l2_0", "bone_l2_1"],
        "bone_l3" : ["bone_l3_0", "bone_l3_1"],
        "bone_l4" : ["bone_l4_0", "bone_l4_1"],
        "t_cycle" : ["t_cycle", "t_cycle"]
      }
    },
    "Rules": [
      {
        "Name": "Humanoid_Pelvis_Ik",
        "Logic": {
          "p_offset": "(bone_l1 + bone_l2)"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "p_offset",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "q1": "-0.022227",
            "q2": "0.706757",
            "q3": "0.022227",
            "qw": "-0.706757"
          }
        ]
      },
      {
        "Name": "Humanoid_Thigh_Ik",
        "Logic": {
          "t_offset": "bone_l1"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "t_offset",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "q1": "0.072944",
            "q2": "0.023874",
            "q3": "-0.040190",
            "qw": "-0.996240"
          }
        ]
      },
      {
        "Name": "Humanoid_Calf_Ik",
        "Logic": {
          "c_offset": "bone_l2"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "c_offset",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "q1": "0.0",
            "q2": "0.0",
            "q3": "-0.009542",
            "qw": "0.999954"
          }
        ]
      },
      {
        "Name": "Humanoid_Foot_Ik_Target",
        "Logic": {
          "p_offset": "(bone_l1 + bone_l2 + bone_l3 + bone_l4)",
          "stride_len": "k * p_offset * sqrt(velocity / p_offset)",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "step_height"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "-p_offset",
            "offset_y": "-((linear_cycle + 0.5) * stride_len)",
            "offset_z": "spacing",
            "q1": "0.0",
            "q2": "0.0",
            "q3": "0.0",
            "qw": "-0.999754"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "(-p_offset) + ( height_offset * sin( _pi * linear_cycle) ) ",
            "offset_y": "((linear_cycle - 0.5) * stride_len)",
            "offset_z": "spacing",
            "q1": "0.0",
            "q2": "0.0",
            "q3": "0.0",
            "qw": "-0.999754"
          }
        ]
      }
    ],
    "Outputs": [
      { "Name": "pelvis_ik", "Space": "LS", "Type": "vec3|Quat", "Size": 7, "Offset": 0 },
      { "Name": "foot_ik",   "Space": "LS", "Type": "vec3|Quat", "Size": 14, "Offset": 7 },
      { "Name": "legs_ik",   "Space": "LS", "Type": "vec3|Quat", "Size": 28, "Offset": 14 }
    ]
  }
}