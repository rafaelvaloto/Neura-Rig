{
  "Profile": "Foot_IK",
  "Version": 3,
  "Schema": {
    "Inputs": [
      { "Name": "velocity",           "Space": "-",  "Type": "float", "Size": 1, "Offset": 0 },

      { "Name": "bone_l1_cm1",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 1 },
      { "Name": "bone_l2_cm1",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 2 },
      { "Name": "ground_one",         "Space": "PS", "Type": "vec3",  "Size": 3, "Offset": 3 },
      { "Name": "has_hit_one",        "Space": "-",  "Type": "flag",  "Size": 1, "Offset": 6 },

      { "Name": "bone_l1_cm2",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 7  },
      { "Name": "bone_l2_cm2",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 8  },
      { "Name": "ground_two",         "Space": "PS", "Type": "vec3",  "Size": 3, "Offset": 9  },
      { "Name": "has_hit_two",        "Space": "-",  "Type": "flag",  "Size": 1, "Offset": 12 },

      { "Name": "delta_sec",          "Space": "-",  "Type": "float", "Size": 1, "Offset": 13 }
    ],
    "Bindings": [
      { "Name": "foot_r", "Target": "Humanoid_Foot_Curve", "Overrides": {"offset": 0.0}},
      { "Name": "foot_l", "Target": "Humanoid_Foot_Curve", "Overrides": {"offset": 0.5}}
    ],
    "Rules": [
      {
        "Name": "Humanoid_Foot_Curve",
        "Constants": {
          "gain": 1.2,
          "frequency": 0.5,
          "limit": 120.0
        },
        "Variables": {
          "delta" : ["delta_sec"],
          "velocity": ["velocity"],
          "bone_l1" : ["bone_l1_cm1", "bone_l1_cm2"],
          "bone_l2" : ["bone_l2_cm1", "bone_l2_cm2"]
        },
        "Logic": {
          "stride_calculation": "min(velocity * gain, (bone_l1 + bone_l2) * 1.2, limit)",
          "cycle": "fmod((delta * frequency) + offset, 1.0)",
          "height": "min(bone_l2 * 0.6, 25.0)"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "cycle < 0.45 && velocity > 0.0",
            "offset_x": "(stride_calculation * 0.5) - ((cycle / 0.45) * stride_calculation)",
            "offset_z": "0.0"
          },
          {
            "id": "swing",
            "condition": "cycle >= 0.45 && velocity > 0.0",
            "progress": "(cycle - 0.45) / 0.55",
            "offset_x": "-(stride_calculation * 0.5) + (progress * stride_calculation)",
            "offset_z": "height * sin(_pi * progress)"
          }
        ]
      }
    ],
    "Outputs": [
      { "Name": "foot_r",           "Space": "LS", "Type": "vec3",  "Size": 3, "Offset": 0 },
      { "Name": "foot_l",           "Space": "LS", "Type": "vec3",  "Size": 3, "Offset": 3 }
    ]
  }
}