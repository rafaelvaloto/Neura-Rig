{
  "Profile": "Foot_IK",
  "Version": 3,
  "Schema": {
    "Inputs": [
      { "Name": "velocity",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 0 },

      { "Name": "bone_l1_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 1 },
      { "Name": "bone_l2_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 2 },
      { "Name": "bone_l3_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 3 },
      { "Name": "bone_l4_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 4 },
      { "Name": "is_hit_0",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 5 },

      { "Name": "offset_0",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 6 },
      { "Name": "spacing_0",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 7 },

      { "Name": "bone_l1_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 8 },
      { "Name": "bone_l2_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 9 },
      { "Name": "bone_l3_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 10 },
      { "Name": "bone_l4_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 11 },
      { "Name": "is_hit_1",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 12 },

      { "Name": "offset_1",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 13 },
      { "Name": "spacing_1",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 14 },
      { "Name": "bone_l0",         "Space": "-",  "Type": "float", "Size": 1, "Offset": 15 },

      { "Name": "t_cycle",         "Space": "-",  "Type": "float", "Size": 1, "Offset": 16 },
      { "Name": "time_dilation",   "Space": "-",  "Type": "float", "Size": 1, "Offset": 17 },
      { "Name": "reserved",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 18 }
    ],
    "Bindings": [
      { "Name": "pelvis", "Target": "Humanoid_Pelvis_Ik", "Limits": { "MinX": -1.0, "MaxX": 1.0, "MinY": -1.0, "MaxY": 1.0, "MinZ": -1.0, "MaxZ": 1.0 }, "Size": 7, "Offset": 0},

      { "Name": "foot_r", "Target": "Humanoid_Foot_Ik_R_Target", "Limits": { "MinX": -0.0, "MaxX": 0.0, "MinY": 0.0, "MaxY": 0.0, "MinZ": 0.0, "MaxZ": 0.0 },   "Size": 7, "Offset": 7 },
      { "Name": "foot_l", "Target": "Humanoid_Foot_Ik_L_Target", "Limits": { "MinX": -0.0, "MaxX": 0.0, "MinY": 0.0, "MaxY": 0.0, "MinZ": 0.0, "MaxZ": 0.0 },   "Size": 7, "Offset": 14},

      { "Name": "calf_r", "Target": "Humanoid_Calf_Ik", "Limits": { "MinX": -0.0, "MaxX": 0.0, "MinY": 0.0, "MaxY": 0.0, "MinZ": 0.0, "MaxZ": 0.0 }, "Size": 7, "Offset": 21},
      { "Name": "calf_l", "Target": "Humanoid_Calf_Ik", "Limits": { "MinX": -0.0, "MaxX": 0.0, "MinY": 0.0, "MaxY": 0.0, "MinZ": 0.0, "MaxZ": 0.0 }, "Size": 7, "Offset": 28},

      { "Name": "thigh_r", "Target": "Humanoid_Thigh_R_Ik", "Limits": { "MinX": 0.0, "MaxX": -90.0, "MinY": -170.0, "MaxY": -190.0, "MinZ": -5.0, "MaxZ": 5.0 }, "Size": 7, "Offset": 35},
      { "Name": "thigh_l", "Target": "Humanoid_Thigh_L_Ik", "Limits": { "MinX": -90.0, "MaxX": 0.0, "MinY": -5.0, "MaxY": 5.0, "MinZ": -170.0, "MaxZ": -190.0 }, "Size": 7, "Offset": 42}
    ],
    "Parameters": {
      "Constants": {
        "k": 1.2,
        "gait_scale": 1.8,
        "step_height": 0.30,
        "max_pitch_norm": 0.25
      },
      "Variables": {
        "velocity": ["velocity", "velocity"],
        "is_hit"  : ["is_hit_0", "is_hit_1"],
        "offset"  : ["offset_0", "offset_1"],
        "spacing" : ["spacing_0", "spacing_1"],
        "bone_l0" : ["bone_l0", "bone_l0"],
        "bone_l1" : ["bone_l1_0", "bone_l1_1"],
        "bone_l2" : ["bone_l2_0", "bone_l2_1"],
        "bone_l3" : ["bone_l3_0", "bone_l3_1"],
        "bone_l4" : ["bone_l4_0", "bone_l4_1"],
        "t_cycle" : ["t_cycle", "t_cycle"]
      }
    },
    "Rules": [
      {
        "Name": "Humanoid_Pelvis_Ik",
        "Logic": {
          "p_offset": "(bone_l1 + bone_l2)",
          "p_length": "bone_l0"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "p_length",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "q1": "0.000000",
            "q2": "0.000000",
            "q3": "0.000000",
            "qw": "1.000000"
          }
        ]
      },
      {
        "Name": "Humanoid_Thigh_R_Ik",
        "Logic": {
          "t_offset": "bone_l1",
          "p_length": "bone_l0"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "0.0",
            "offset_y": "p_length * 0.5",
            "offset_z": "t_offset",
            "q1": "0.000000",
            "q2": "0.000000",
            "q3": "1.000000",
            "qw": "0.000000"
          }
        ]
      },
      {
        "Name": "Humanoid_Thigh_L_Ik",
        "Logic": {
          "t_offset": "bone_l1",
          "p_length": "bone_l0"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "0.0",
            "offset_y": "p_length * -0.5",
            "offset_z": "t_offset",
            "q1": "0.000000",
            "q2": "0.000000",
            "q3": "0.000000",
            "qw": "1.000000"
          }
        ]
      },
      {
        "Name": "Humanoid_Calf_Ik",
        "Logic": {
          "c_offset": "bone_l2",
          "p_length": "bone_l0"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "q1": "0.000000",
            "q2": "0.000000",
            "q3": "0.000000",
            "qw": "0.000000"
          }
        ]
      },
      {
        "Name": "Humanoid_Foot_Ik_R_Target",
        "Logic": {
          "f_offset": "(bone_l1 + bone_l2)",
          "stride_len": "k * f_offset * sqrt(velocity / f_offset)",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "step_height",
          "p_offset": "bone_l0"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "-f_offset",
            "offset_y": "-((linear_cycle + 0.5) * stride_len)",
            "offset_z": "0.30",
            "q1": "0.000000",
            "q2": "0.000000",
            "q3": "0.000000",
            "qw": "0.000000"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "((linear_cycle - 0.5) * stride_len)",
            "offset_y": "0.30",
            "offset_z": "(-f_offset) + ( height_offset * sin( _pi * linear_cycle) )",
            "q1": "0.000000",
            "q2": "0.000000",
            "q3": "0.000000",
            "qw": "0.000000"
          }
        ]
      },
      {
        "Name": "Humanoid_Foot_Ik_L_Target",
        "Logic": {
          "f_offset": "(bone_l1 + bone_l2)",
          "stride_len": "k * f_offset * sqrt(velocity / f_offset)",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "step_height",
          "p_offset": "bone_l0"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "-0.30",
            "offset_y": "-((linear_cycle + 0.5) * stride_len)",
            "offset_z": "-f_offset",
            "q1": "0.000000",
            "q2": "0.000000",
            "q3": "0.000000",
            "qw": "0.000000"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "((linear_cycle - 0.5) * stride_len)",
            "offset_y": "-0.30",
            "offset_z": "(-f_offset) + ( height_offset * sin( _pi * linear_cycle) )",
            "q1": "0.000000",
            "q2": "0.000000",
            "q3": "0.000000",
            "qw": "0.000000"
          }
        ]
      }
    ],
    "Outputs": [
      { "Name": "pelvis_ik", "Space": "LS", "Type": "vec3|Quat", "Size": 7, "Offset": 0 },
      { "Name": "foot_ik",   "Space": "LS", "Type": "vec3|Quat", "Size": 14, "Offset": 7 },
      { "Name": "legs_ik",   "Space": "LS", "Type": "vec3|Quat", "Size": 28, "Offset": 14 }
    ]
  }
}