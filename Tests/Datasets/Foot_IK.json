{
  "Profile": "Foot_IK",
  "Version": 3,
  "Schema": {
    "Inputs": [
      { "Name": "velocity",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 0 },

      { "Name": "bone_l1_r",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 1 },
      { "Name": "bone_l2_r",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 2 },
      { "Name": "offset_r",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 3 },
      { "Name": "spacing_r",       "Space": "-", "Type": "float", "Size": 1, "Offset": 4 },


      { "Name": "bone_l1_l",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 5 },
      { "Name": "bone_l2_l",       "Space": "-",  "Type": "float", "Size": 1, "Offset": 6 },
      { "Name": "offset_l",        "Space": "-",  "Type": "float", "Size": 1, "Offset": 7 },
      { "Name": "spacing_l",        "Space": "-", "Type": "float", "Size": 1, "Offset": 8 },

      { "Name": "t_cycle",         "Space": "-",  "Type": "float", "Size": 1, "Offset": 9 },
      { "Name": "time_dilation",   "Space": "-",  "Type": "float", "Size": 1, "Offset": 10 },
      { "Name": "t_accumulated",   "Space": "-",  "Type": "float", "Size": 1, "Offset": 11 }
    ],
    "Bindings": [
      { "Name": "foot_r", "Target": "Humanoid_Foot_Ik_Curve", "Size": 6, "Offset": 0 },
      { "Name": "foot_l", "Target": "Humanoid_Foot_Ik_Curve", "Size": 6, "Offset": 6 },
      { "Name": "ball_r", "Target": "Humanoid_Ball_Ik_Curve", "Size": 6, "Offset": 12},
      { "Name": "ball_l", "Target": "Humanoid_Ball_Ik_Curve", "Size": 6, "Offset": 18},
      { "Name": "calf_r", "Target": "Humanoid_Calf_Ik_Curve", "Size": 6, "Offset": 24},
      { "Name": "calf_l", "Target": "Humanoid_Calf_Ik_Curve", "Size": 6, "Offset": 30},
      { "Name": "thigh_r", "Target": "Humanoid_Thigh_Ik_Curve", "Size": 6, "Offset": 36},
      { "Name": "thigh_l", "Target": "Humanoid_Thigh_Ik_Curve", "Size": 6, "Offset": 42},
      { "Name": "pelvis", "Target": "Humanoid_Pelvis_Ik_Curve", "Size": 6, "Offset": 48},
      { "Name": "spine",  "Target": "Humanoid_Spine_Ik_Curve", "Size": 6, "Offset": 54}
    ],
    "Parameters": {
      "Constants": {
        "k": 1.6,
        "gait_scale": 3.8,
        "step_height": 0.45,
        "max_pitch_norm": 0.45
      },
      "Variables": {
        "velocity": ["velocity", "velocity"],
        "offset"  : ["offset_r", "offset_l"],
        "bone_l1" : ["bone_l1_r", "bone_l1_l"],
        "bone_l2" : ["bone_l2_r", "bone_l2_l"],
        "spacing" : ["spacing_r", "spacing_l"],
        "t_cycle" : ["t_cycle", "t_cycle"]
      }
    },
    "Rules": [
      {
        "Name": "Humanoid_Foot_Ik_Curve",
        "Logic": {
          "stride_len": "k * sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 1.0, step_height)"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "-((linear_cycle + 0.5) * stride_len)",
            "offset_y": "spacing",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "((linear_cycle - 0.5) * stride_len)",
            "offset_y": "spacing",
            "offset_z": "height_offset * sin(_pi * linear_cycle)",
            "rot_pitch": "max_pitch_norm * sin(_pi * linear_cycle)",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Ball_Ik_Curve",
        "Logic": {
          "stride_len": "k * sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 1.0, step_height)"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.0",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Calf_Ik_Curve",
        "Logic": {
          "stride_len": "k * sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 1.0, step_height)"
        },
        "Phases": [
          {
            "id": "stance",
            "condition": "linear_cycle < 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "0.45 * sin(_pi * (linear_cycle + 1.0))",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          },
          {
            "id": "swing",
            "condition": "linear_cycle >= 0.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "min(1.0, linear_cycle * 6.0) * cos(max(0.0, linear_cycle - 0.5) * _pi)",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Thigh_Ik_Curve",
        "Logic": {
          "stride_len": "k * sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 1.0, step_height)"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "cos(_pi * stride_len)",
            "rot_yaw": "0.0",
            "rot_roll": "0.0"
          }
        ]
      },
      {
        "Name": "Humanoid_Pelvis_Ik_Curve",
        "Logic": {
          "stride_len": "k * sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 1.0, step_height)"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "0.0",
            "offset_y": "sin(_pi * linear_cycle)",
            "offset_z": "(cos(2.0 * _pi * linear_cycle) - 1.0) * 0.5",
            "rot_pitch": "-sin(_pi * linear_cycle)",
            "rot_yaw": "0.0",
            "rot_roll": "sin(_pi * linear_cycle)"
          }
        ]
      },
      {
        "Name": "Humanoid_Spine_Ik_Curve",
        "Logic": {
          "stride_len": "k * sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 1.0, step_height)"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "clamp(velocity / 1.0, 0.0, 1.0)",
            "rot_yaw": "-sin(_pi * linear_cycle)",
            "rot_roll": "-sin(_pi * linear_cycle) * 0.5"
          }
        ]
      },
      {
        "Name": "Humanoid_Arm_Ik_Curve",
        "Logic": {
          "stride_len": "k * sqrt(velocity / (bone_l1 + bone_l2))",
          "stride_freq": "velocity / stride_len",
          "T_gait": "(1.0 / stride_freq) * gait_scale",
          "phase_offset": "fmod((t_cycle / T_gait) + offset, 1.0)",
          "linear_cycle": "2.0 * phase_offset - 1.0",
          "height_offset": "min(bone_l2 * 1.0, step_height)"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "0.0",
            "offset_y": "0.0",
            "offset_z": "0.0",
            "rot_pitch": "sin(_pi * linear_cycle)",
            "rot_yaw": "0.0",
            "rot_roll": "(cos(2.0 * _pi * linear_cycle) - 1.0) * 0.5"
          }
        ]
      }
    ],
    "Outputs": [
      { "Name": "foot_ik", "Space": "LS", "Type": "vec3",  "Size": 36, "Offset": 0 },
      { "Name": "foot_ik", "Space": "LS", "Type": "vec3",  "Size": 12, "Offset": 36 },
      { "Name": "pelvis_ik", "Space": "LS", "Type": "vec3",  "Size": 6, "Offset": 48 },
      { "Name": "spine_ik", "Space": "LS", "Type": "vec3",  "Size": 6, "Offset": 54 }
    ]
  }
}