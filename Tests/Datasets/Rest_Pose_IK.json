          "f_offset": "bone_l2 + bone_l1"
        },
        "Phases": [
          {
            "id": "global",
            "condition": "1.0",
            "offset_x": "-f_offset",
            "offset_y": "-0.10",
            "offset_z": "-0.05"
          }
        ]
      }
